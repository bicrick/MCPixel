# MCPixel
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
REMOVE_BG_API_KEY=

# Server
HOST=127.0.0.1
PORT=8787
PUBLIC_BASE_URL=http://127.0.0.1:8787
DATA_DIR=./data

# Pixel Snapper binary (dev default: sibling Desktop checkout release build)
SNAPPER_BIN=/Users/pbrown/Desktop/spritefusion-pixel-snapper/target/release/spritefusion-pixel-snapper

# rembg model: birefnet-general | u2net | isnet-general-use
REMBG_MODEL=birefnet-general
ALPHA_HARDEN_THRESHOLD=128

# MCP client (used by mcpixel-mcp process)
MCPIXEL_URL=http://127.0.0.1:8787
